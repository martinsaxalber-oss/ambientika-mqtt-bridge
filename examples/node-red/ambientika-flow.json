  {
    "id": "notify-filter-alarm",
    "type": "function",
    "z": "ambientika-tab",
    "name": "Build Filter Notification",
    "func": "const serial = msg.topic.split('/')[1];\nmsg.payload = {\n    title: 'Ambientika Filter Service',\n    message: 'Device ' + serial + ' requires filter maintenance. Please replace or clean the filter.',\n    priority: 'high'\n};\nmsg.topic = 'notifications/ambientika/filter';\nreturn msg;",
