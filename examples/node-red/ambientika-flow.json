    "id": "set-context",
    "type": "change",
    "z": "ambientika-tab",
    "name": "Store in Context",
    "rules": [
      {"t": "set", "p": "ambientika_state", "pt": "flow", "to": "payload", "tot": "msg"},
      {"t": "set", "p": "ambientika_serial", "pt": "flow", "to": "serial", "tot": "msg"}
    ],
