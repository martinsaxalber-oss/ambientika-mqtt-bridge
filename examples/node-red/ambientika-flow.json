  {
    "id": "humidity-auto-logic",
    "type": "function",
    "z": "ambientika-tab",
    "name": "Auto Boost on High Humidity",
    "func": "// Auto-boost ventilation when humidity > 75%\nconst humidity = msg.payload.humidity;\nconst serial = msg.topic.split('/')[1];\n\nif (humidity > 75) {\n    // High humidity: switch to ManualHigh\n    return {\n        topic: 'ambientika/' + serial + '/set/operating_mode',\n        payload: 'ManualHigh'\n    };\n} else if (humidity < 60) {\n    // Back to Auto when humidity is normal\n    return {\n        topic: 'ambientika/' + serial + '/set/operating_mode',\n        payload: 'Auto'\n    };\n}\n// No action needed\nreturn null;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 360,
    "y": 820,
    "wires": [["mqtt-cmd-out-auto", "debug-auto"]]
  },
