  {
    "id": "comment-intro",
    "type": "comment",
    "z": "ambientika-tab",
    "name": "Ambientika MQTT Bridge - Node-RED Flow",
    "info": "This flow connects to the Ambientika MQTT Bridge.\n\nPrerequisites:\n1. ambientika-mqtt-bridge is running (see README)\n2. MQTT broker is configured (default: localhost:1883)\n3. Update DEVICE_SERIAL below with your device serial number\n\nTopics:\n- Status: ambientika/{serial}/state\n- Commands: ambientika/{serial}/set/{property}\n\nEdit the mqtt-broker node to point to your broker.",
    "x": 150,
    "y": 40,
    "wires": []
  },
  {
    "id": "mqtt-state-in",
    "type": "mqtt in",
    "z": "ambientika-tab",
    "name": "Device State",
    "topic": "ambientika/+/state",
    "qos": "1",
    "datatype": "json",
    "broker": "mqtt-broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 130,
    "y": 120,
    "wires": [["parse-state", "debug-state"]]
  },
  {
    "id": "parse-state",
    "type": "function",
    "z": "ambientika-tab",
    "name": "Parse State",
    "func": "// Extract device serial from topic\nconst parts = msg.topic.split('/');\nconst serial = parts[1];\n\n// Store full state in flow context\nflow.set('device_' + serial, msg.payload);\nflow.set('last_serial', serial);\n\n// Set useful properties on msg\nmsg.serial = serial;\nmsg.state = msg.payload;\n\n// Create human-readable summary\nconst s = msg.payload;\nmsg.summary = {\n    serial: serial,\n    mode: s.operating_mode,\n    fan_speed: s.fan_speed,\n    humidity: s.humidity + ' %',\n    temp_supply: s.supply_air_temperature + ' Â°C',\n    temp_extract: s.extract_air_temperature + ' Â°C',\n    air_quality: s.air_quality,\n    filter_ok: !s.filter_alarm,\n    online: true\n};\n\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 330,
    "y": 120,
    "wires": [["set-context", "dashboard-update"]]
  },
